import UIKit
import Metal
import MetalKit

class WaveformView: MTKView {
    private var commandQueue: MTLCommandQueue?
    private var renderPipelineState: MTLRenderPipelineState?
    private var audioBuffer: [Float] = []
    private var vertexBuffer: MTLBuffer?
    
    var waveformColor: UIColor = UIColor(hex: "#00CEC9") {
        didSet { setNeedsDisplay() }
    }
    
    override init(frame frameRect: CGRect, device: MTLDevice?) {
        super.init(frame: frameRect, device: device ?? MTLCreateSystemDefaultDevice())
        setupMetal()
    }
    
    required init(coder: NSCoder) {
        super.init(coder: coder)
        device = MTLCreateSystemDefaultDevice()
        setupMetal()
    }
    
    private func setupMetal() {
        guard let device = device else { return }
        
        commandQueue = device.makeCommandQueue()
        
        // Create render pipeline
        let library = device.makeDefaultLibrary()
        let vertexFunction = library?.makeFunction(name: "waveformVertexShader")
        let fragmentFunction = library?.makeFunction(name: "waveformFragmentShader")
        
        let pipelineDescriptor = MTLRenderPipelineDescriptor()
        pipelineDescriptor.vertexFunction = vertexFunction
        pipelineDescriptor.fragmentFunction = fragmentFunction
        pipelineDescriptor.colorAttachments[0].pixelFormat = colorPixelFormat
        
        renderPipelineState = try? device.makeRenderPipelineState(descriptor: pipelineDescriptor)
        
        delegate = self
    }
    
    func updateAudioBuffer(_ buffer: [Float]) {
        audioBuffer = buffer
        
        // Create vertex data from audio buffer
        let vertices = createVertices(from: buffer)
        
        guard let device = device else { return }
        vertexBuffer = device.makeBuffer(bytes: vertices, length: vertices.count * MemoryLayout<Float>.size, options: [])
        
        setNeedsDisplay()
    }
    
    private func createVertices(from audioBuffer: [Float]) -> [Float] {
        var vertices: [Float] = []
        let width = Float(bounds.width)
        let height = Float(bounds.height)
        
        for (index, sample) in audioBuffer.enumerated() {
            let x = (Float(index) / Float(audioBuffer.count)) * 2.0 - 1.0
            let y = sample * 0.8 // Scale amplitude
            
            vertices.append(x)
            vertices.append(y)
        }
        
        return vertices
    }
}

extension WaveformView: MTKViewDelegate {
    func mtkView(_ view: MTKView, drawableSizeWillChange size: CGSize) {
        // Handle size changes
    }
    
    func draw(in view: MTKView) {
        guard let commandBuffer = commandQueue?.makeCommandBuffer(),
              let renderEncoder = commandBuffer.makeRenderCommandEncoder(descriptor: currentRenderPassDescriptor!),
              let pipelineState = renderPipelineState,
              let vertexBuffer = vertexBuffer else { return }
        
        renderEncoder.setRenderPipelineState(pipelineState)
        renderEncoder.setVertexBuffer(vertexBuffer, offset: 0, index: 0)
        
        let colorComponents = waveformColor.cgColor.components ?? [0, 0, 0, 1]
        var color = SIMD4<Float>(Float(colorComponents[0]), Float(colorComponents[1]), Float(colorComponents[2]), Float(colorComponents[3]))
        renderEncoder.setFragmentBytes(&color, length: MemoryLayout<SIMD4<Float>>.size, index: 0)
        
        renderEncoder.drawPrimitives(type: .lineStrip, vertexStart: 0, vertexCount: audioBuffer.count)
        renderEncoder.endEncoding()
        
        commandBuffer.present(currentDrawable!)
        commandBuffer.commit()
    }
}
