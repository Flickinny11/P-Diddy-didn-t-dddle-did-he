import AVFoundation
import Metal

class AudioEngine: ObservableObject {
    private let audioEngine = AVAudioEngine()
    private let playerNode = AVAudioPlayerNode()
    private let mixerNode = AVAudioMixerNode()
    private let reverbEffect = AVAudioUnitReverb()
    private let delayEffect = AVAudioUnitDelay()
    private let distortionEffect = AVAudioUnitDistortion()
    
    @Published var isPlaying = false
    @Published var currentTime: TimeInterval = 0
    @Published var duration: TimeInterval = 0
    @Published var volume: Float = 0.8
    
    private var audioFile: AVAudioFile?
    private var displayLink: CADisplayLink?
    
    init() {
        setupAudioEngine()
        setupDisplayLink()
    }
    
    private func setupAudioEngine() {
        // Attach nodes
        audioEngine.attach(playerNode)
        audioEngine.attach(mixerNode)
        audioEngine.attach(reverbEffect)
        audioEngine.attach(delayEffect)
        audioEngine.attach(distortionEffect)
        
        // Connect nodes
        audioEngine.connect(playerNode, to: reverbEffect, format: nil)
        audioEngine.connect(reverbEffect, to: delayEffect, format: nil)
        audioEngine.connect(delayEffect, to: distortionEffect, format: nil)
        audioEngine.connect(distortionEffect, to: mixerNode, format: nil)
        audioEngine.connect(mixerNode, to: audioEngine.outputNode, format: nil)
        
        // Prepare and start engine
        audioEngine.prepare()
        try? audioEngine.start()
    }
    
    func loadAudioFile(_ file: AVAudioFile) {
        audioFile = file
        duration = Double(file.length) / file.fileFormat.sampleRate
    }
    
    func play() {
        guard let audioFile = audioFile else { return }
        
        playerNode.scheduleFile(audioFile, at: nil) { [weak self] in
            DispatchQueue.main.async {
                self?.isPlaying = false
            }
        }
        
        playerNode.play()
        isPlaying = true
    }
    
    func pause() {
        playerNode.pause()
        isPlaying = false
    }
    
    func stop() {
        playerNode.stop()
        isPlaying = false
        currentTime = 0
    }
    
    // Effect controls
    func setReverbWetDryMix(_ value: Float) {
        reverbEffect.wetDryMix = value
    }
    
    func setDelayWetDryMix(_ value: Float) {
        delayEffect.wetDryMix = value
    }
    
    func setDistortionWetDryMix(_ value: Float) {
        distortionEffect.wetDryMix = value
    }
}
